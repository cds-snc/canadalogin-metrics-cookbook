# AWS named profile used for the Athena connection (profile in aws sso login --profile)
AWS_PROFILE=cl-data

# AWS region the Athena workgroup lives in.
AWS_REGION=ca-central-1

# S3 location Athena writes query results to (note the trailing slash).
ATHENA_S3_STAGING_DIR=s3://athena-results-bucket-example/
